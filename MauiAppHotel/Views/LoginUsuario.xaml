<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.LoginUsuario"
             Title="LoginUsuario">
    <VerticalStackLayout Margin="10" Spacing="10">
        <Label Text="Realize o seu login" Margin="40" HorizontalOptions="Center" VerticalOptions="Center" FontFamily="DancingScript" FontSize="30"/>

        <Border Padding="10">
            <VerticalStackLayout>
                <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                    <Label Grid.Row="0" Text="E-mail"/>
                    <Entry Grid.Row="1" x:Name="email_usuario" Placeholder="example@email.com"/>

                    <Label Grid.Row="2" Text="Senha"/>
                    <Entry Grid.Row="3" IsPassword="True" x:Name="senha_usuario" Placeholder="******"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Button Text="Entrar" Clicked="Button_Clicked_Entrar"/>
        <Button Text="Criar cadastro" Clicked="Button_Clicked_Cadastrar"/>
    </VerticalStackLayout>
</ContentPage>