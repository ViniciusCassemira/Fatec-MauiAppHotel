<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.CadastroUsuario"
             Title="CadastroUsuario">

    <VerticalStackLayout>

        <Label Margin="40" Text="Crie seu cadastro" HorizontalOptions="Center" VerticalOptions="Center" FontFamily="DancingScript" FontSize="30"/>

        <Border Margin="10" BackgroundColor="{StaticResource Black}">
            <VerticalStackLayout Margin="10" Spacing="10">
                
                <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto">

                    <Label Grid.Row="0" Text="Seu nome"/>
                    <Entry Grid.Row="1" x:Name="nome_usuario" Placeholder="Vinicius Sousa"/>

                    <Label Grid.Row="2" Text="Seu melhor e-mail"/>
                    <Entry Grid.Row="3" x:Name="email_usuario" Placeholder="example@email.com"/>

                    <Label Grid.Row="4" Text="Uma senha segura"/>
                    <Entry Grid.Row="5" x:Name="senha_usuario" Placeholder="mínimo de 6 dígitos"/>
                </Grid>

                <Button Text="Criar conta" HorizontalOptions="Center" Clicked="Button_Clicked"/>
                
            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>

</ContentPage>